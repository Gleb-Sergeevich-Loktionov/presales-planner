# Database Configuration
# PostgreSQL connection string for task planning database
DATABASE_URL=postgresql+asyncpg://planner:planner@localhost:5432/planner

# Redis Configuration
# Redis cache connection string
REDIS_URL=redis://localhost:6379/0

# Telegram Configuration
# Bot token obtained from BotFather
BOT_TOKEN=your_bot_token_here

# Team chat ID for notifications (obtain from @userinfobot)
TEAM_CHAT_ID=123456789

# LLM Configuration
# Anthropic API key for Claude models
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Notion Configuration (optional — Telegram→Notion task mirror)
# Internal integration token; share the integration with the target DB.
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Web Configuration
# Secret for webhook validation (optional, can be empty)
WEBHOOK_SECRET=

# Application Configuration
# Timezone for scheduling (default: Europe/Moscow)
TIMEZONE=Europe/Moscow

# Debug mode. MUST be false in production (DEBUG=false): debug enables the
# loopback /dev-login session shortcut. Leave false unless developing locally.
DEBUG=false

# Admin session signing secret. REQUIRED in production — set a strong, random
# value via env/secret-manager (never commit it).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# The app refuses to start with DEBUG=false while this is left at the default.
JWT_SECRET=
